# ── Server ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────
DATABASE_URL=postgresql://amisafe:amisafe_dev@localhost:5432/amisafe

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ────────────────────────────────────────
# Generate with: openssl rand -hex 32
PARTNER_API_SECRET=replace_with_strong_secret_32_chars_min

# ── CORS ────────────────────────────────────────────
ALLOWED_ORIGINS=chrome-extension://your-extension-id,https://dashboard.amisafe.org

# ── Rate limits ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ── Whisper API (optional — for server-side transcription fallback) ──
WHISPER_API_URL=
WHISPER_API_KEY=

# ── Dashboard base URL ──────────────────────────────
DASHBOARD_URL=https://dashboard.amisafe.org

# ── Logging ─────────────────────────────────────────
LOG_LEVEL=info
