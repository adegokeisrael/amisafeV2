{
  "name": "amisafe-api",
  "version": "0.1.0",
  "private": true,
  "description": "AmiSafe REST API — report intake, anonymisation, pattern detection",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev":     "nodemon src/index.js",
    "start":   "node src/index.js",
    "migrate": "node src/db/migrate.js",
    "seed":    "node src/db/seed.js",
    "test":    "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "express":          "^4.19.2",
    "pg":               "^8.12.0",
    "ioredis":          "^5.3.2",
    "uuid":             "^9.0.1",
    "helmet":           "^7.1.0",
    "cors":             "^2.8.5",
    "express-rate-limit": "^7.3.1",
    "compromise":       "^14.13.0",
    "dotenv":           "^16.4.5",
    "pino":             "^9.2.0",
    "pino-pretty":      "^11.2.1",
    "zod":              "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "jest":    "^29.7.0"
  }
}
