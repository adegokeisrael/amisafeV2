# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public URL of this API (no trailing slash)
PUBLIC_URL=http://localhost:3000

# ── PostgreSQL ──────────────────────────────────────────────────
# Render sets this automatically when you link a database.
# For local dev, create a local Postgres DB and paste the URL here.
DATABASE_URL=postgres://user:password@localhost:5432/amisafe

# ── Cloudflare R2 ───────────────────────────────────────────────
# Found in Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=amisafe-evidence

# Public URL for the R2 bucket (enable public access in R2 dashboard,
# or use a custom domain). Evidence files are stored with private
# keys so this URL alone is not enough to access them.
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ── Auth ────────────────────────────────────────────────────────
# Random 32-byte hex string used to verify partner API keys.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SECRET=replace_with_random_64_char_hex

# ── Rate limiting ────────────────────────────────────────────────
# Max report submissions per IP per 15 minutes
RATE_LIMIT_REPORTS=20

# Max dashboard requests per IP per minute
RATE_LIMIT_DASHBOARD=60
