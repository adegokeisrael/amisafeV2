{
  "manifest_version": 3,
  "name": "AmiSafe",
  "version": "0.1.0",
  "description": "Report AI-related harms in your community — safely, privately, in your language.",
  "homepage_url": "https://amisafe.org",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "offscreen"
  ],

  "host_permissions": [
    "https://api.amisafe.org/*",
    "http://localhost:3001/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AmiSafe — Report AI harm"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*", "popup/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "default_locale": "en",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
